# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/captivia?schema=public"

# Server Configuration (backend: 3001, frontend Next.js: 3000)
PORT=3001
# HOST=0.0.0.0  # optionnel : écoute sur toutes les interfaces (pour accès téléphone)

# GBIF API Configuration (optional, uses default if not set)
# GBIF_API_BASE_URL="https://api.gbif.org/v1"

# Wikipedia API Configuration (free, no API key required)
WIKIPEDIA_API_BASE_URL="https://en.wikipedia.org/api/rest_v1"
WIKIPEDIA_RATE_LIMIT=100
WIKIPEDIA_RATE_WINDOW=60000

# Wikidata API Configuration (free, no API key required)
WIKIDATA_API_BASE_URL="https://query.wikidata.org/sparql"
WIKIDATA_RATE_LIMIT=100
WIKIDATA_RATE_WINDOW=60000

# Cache Configuration
# Choose cache implementation: 'redis', 'memcached', or 'memory'
CACHE_TYPE="memory"

# Redis Configuration (if CACHE_TYPE=redis)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600

# Memcached Configuration (if CACHE_TYPE=memcached)
MEMCACHED_HOST=localhost
MEMCACHED_PORT=11211

# API Rate Limiting
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_TTL=3600

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"

# JWT Configuration (REQUIRED - use a strong random string of 32+ chars)
JWT_SECRET="change-me-to-a-strong-random-secret-at-least-32-chars"
JWT_EXPIRATION="7d"

# Opérateur : email(s) avec accès complet sans abonnement (séparés par des virgules)
OPERATOR_EMAIL=your-email@example.com
# ou plusieurs : OPERATOR_EMAILS=op1@example.com,op2@example.com

# Species+ API Configuration
SPECIESPLUS_API_TOKEN="your-token-here"

# Amazon Product Advertising API Configuration
AMAZON_ACCESS_KEY="your-access-key"
AMAZON_SECRET_KEY="your-secret-key"
AMAZON_AFFILIATE_TAG="your-affiliate-tag"
AMAZON_MARKETPLACE="www.amazon.com"

# Push Notifications Configuration (Web Push VAPID)
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:contact@captivia.com"

# Password reset email (optional; if not set, reset link is logged to console)
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=your-email@example.com
# MAIL_PASS=your-password
# MAIL_FROM=Captivia <noreply@captivia.com>
# Frontend URL for reset link (e.g. http://localhost:3001)
FRONTEND_URL=http://localhost:3001